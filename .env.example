# Copy to .env and edit. This file is safe to commit; .env is not.

# Host the Fastify server binds to.
# Use 127.0.0.1 for local-only access. Use 0.0.0.0 to expose on all
# interfaces (NOT recommended until auth middleware lands, see roadmap).
HOST=127.0.0.1

# Port the Fastify server listens on.
PORT=8787

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Default model used when a chat completion request omits `model`.
# Must match a model id returned by GET /v1/models.
DEFAULT_MODEL=mock-gpt-4o-mini

# --- Provider credentials (NOT used in milestone 1) ---
# Real provider keys land in milestone 2. When they do, they go here,
# read from process.env only — never written to disk, never committed.
# Example (DO NOT fill in yet):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
