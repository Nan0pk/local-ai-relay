# Copy to .env and edit. This file is safe to commit; .env is not.

# Host the Fastify server binds to.
# Use 127.0.0.1 for local-only access. Use 0.0.0.0 to expose on all
# interfaces (not recommended; explicit acknowledgement and token required).
HOST=127.0.0.1

# Port the Fastify server listens on.
PORT=8787

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Default model used when a chat completion request omits `model`.
# Must match a model id returned by GET /v1/models.
DEFAULT_MODEL=mock-gpt-4o-mini

# Dedicated Patchright profile for ChatGPT web. Never point this at your
# everyday Chrome profile. Default:
# ~/.local-ai-relay/browser-profiles/chatgpt
# RELAY_BROWSER_PROFILE=

# Dedicated Patchright profile for Claude web. Default:
# ~/.local-ai-relay/browser-profiles/claude
# RELAY_BROWSER_PROFILE_CLAUDE=

# Dedicated Patchright profile for Meta AI web. Default:
# ~/.local-ai-relay/browser-profiles/meta
# RELAY_BROWSER_PROFILE_META=

# Optional managed browser binaries live under ./.relay-browser/browsers and
# are gitignored. Setup does not download them automatically.
# PLAYWRIGHT_BROWSERS_PATH=
# Optional system Chromium/Chrome executable instead of automatic detection.
# Standard Chrome/Chromium locations are detected on Windows, macOS, and Linux.
# RELAY_BROWSER_EXECUTABLE=

# Browser requests are visible by default. Headless mode is experimental.
RELAY_BROWSER_HEADLESS=0
RELAY_BROWSER_TIMEOUT_MS=180000

# Bound sticky pages so abandoned harness sessions cannot grow forever.
RELAY_BROWSER_MAX_SESSIONS=8

# A local screenshot is written on browser failures. It can contain prompt
# content; set this to 0 to disable it.
RELAY_DIAGNOSTICS=1
# RELAY_DIAGNOSTICS_DIR=

# ChatGPT and Claude web authentication is never configured here. Sign in
# normally in the dedicated browser opened by `npm run login:chatgpt` or
# `npm run login:claude`. Never copy cookies, session tokens, or passwords
# into this file.
