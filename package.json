{
  "name": "local-ai-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI relay that exposes one OpenAI-compatible endpoint for agent harnesses.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "test:e2e": "node --import tsx --test tests/e2e/e2e.test.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "browser:install": "node --import tsx src/cli/browser-install.ts",
    "browser:login": "node --import tsx src/cli/browser-login.ts",
    "login:chatgpt": "node --import tsx src/cli/browser-login.ts --provider chatgpt",
    "login:claude": "node --import tsx src/cli/browser-login.ts --provider claude",
    "login:gemini": "node --import tsx src/cli/browser-login.ts --provider gemini",
    "login:deepseek": "node --import tsx src/cli/browser-login.ts --provider deepseek",
    "login:zai": "node --import tsx src/cli/browser-login.ts --provider zai",
    "login:minimax": "node --import tsx src/cli/browser-login.ts --provider minimax",
    "login:kimi": "node --import tsx src/cli/browser-login.ts --provider kimi",
    "login:qwen": "node --import tsx src/cli/browser-login.ts --provider qwen",
    "login:grok": "node --import tsx src/cli/browser-login.ts --provider grok",
    "login:mistral": "node --import tsx src/cli/browser-login.ts --provider mistral",
    "login:meta": "node --import tsx src/cli/browser-login.ts --provider meta",
    "probe:chatgpt": "node --import tsx src/cli/live-probe.ts --provider chatgpt",
    "probe:claude": "node --import tsx src/cli/live-probe.ts --provider claude",
    "probe:gemini": "node --import tsx src/cli/live-probe.ts --provider gemini",
    "probe:deepseek": "node --import tsx src/cli/live-probe.ts --provider deepseek",
    "probe:zai": "node --import tsx src/cli/live-probe.ts --provider zai",
    "probe:minimax": "node --import tsx src/cli/live-probe.ts --provider minimax",
    "probe:kimi": "node --import tsx src/cli/live-probe.ts --provider kimi",
    "probe:qwen": "node --import tsx src/cli/live-probe.ts --provider qwen",
    "probe:grok": "node --import tsx src/cli/live-probe.ts --provider grok",
    "probe:mistral": "node --import tsx src/cli/live-probe.ts --provider mistral",
    "probe:meta": "node --import tsx src/cli/live-probe.ts --provider meta",
    "probe:all": "node --import tsx scripts/probe-all.ts",
    "smoke:claude-driver": "node --import tsx scripts/claude-driver-smoke.ts",
    "smoke:startup": "npm run build && node dist/cli/startup-smoke.js",
    "test:delivery": "node --import tsx --test src/delivery/*.test.ts",
    "service:install": "node --env-file-if-exists=.env --import tsx src/cli/install-service.ts",
    "service:start:windows": "node --env-file-if-exists=.env --import tsx src/cli/start-windows-service.ts",
    "hermes:configure": "node --env-file-if-exists=.env --import tsx src/cli/configure-hermes.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "fastify": "^5.2.1",
    "patchright": "^1.61.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
